PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=idempotency_db

# =========================
# DATABASE URL
# =========================
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/idempotency_db
